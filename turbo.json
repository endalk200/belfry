{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"globalDependencies": ["scripts/**"],
	"ui": "stream",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"transit": {
			"dependsOn": ["^transit"]
		},
		"lint": {
			"dependsOn": ["transit"],
			"outputs": []
		},
		"lint:fix": {
			"cache": false
		},
		"test": {
			"dependsOn": ["transit"],
			"outputs": []
		},
		"format": {
			"cache": false
		},
		"format:check": {
			"dependsOn": ["transit"],
			"outputs": []
		},
		"check-types": {
			"dependsOn": ["transit"],
			"outputs": []
		}
	}
}
